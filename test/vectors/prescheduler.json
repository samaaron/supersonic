{
  "_doc": [
    "Language-neutral behavioral vectors for the OSC-out prescheduler.",
    "Every host must reproduce every vector: the web worker",
    "(js/workers/osc_out_prescheduler_worker.js), the portable C++ core",
    "(src/workers/PreschedulerCore.cpp), and the embedded FreeRTOS wrapper.",
    "This file is the single source of truth for prescheduler semantics.",
    "",
    "Model: a test driver feeds 'ops' in order on a logical clock measured in",
    "seconds. It advances 'now' to each op's t, applies the op, then advances",
    "past all due times and records what was dispatched and in what order.",
    "An event due at D is released (dispatched) at D - lookahead. Cancelled and",
    "rejected events never dispatch. 'id' is an opaque label for assertions.",
    "Output-side backpressure (ring-buffer-full retry) is sink-specific and is",
    "covered separately, not here."
  ],

  "defaults": {
    "lookahead_s": 0.5,
    "max_pending": 1000,
    "max_future_s": 3600,
    "pool_bytes": 524288
  },

  "vectors": [
    {
      "name": "ordering: dispatch in due-time order regardless of schedule order",
      "ops": [
        { "t": 0.0, "schedule": { "id": "a", "due": 3.0 } },
        { "t": 0.0, "schedule": { "id": "b", "due": 1.0 } },
        { "t": 0.0, "schedule": { "id": "c", "due": 2.0 } }
      ],
      "expect": { "dispatched": ["b", "c", "a"] }
    },

    {
      "name": "lookahead: event due at D is released at D - lookahead",
      "lookahead_s": 0.5,
      "ops": [
        { "t": 0.0, "schedule": { "id": "a", "due": 2.0 } }
      ],
      "expect": { "dispatched": ["a"], "released_at": { "a": 1.5 } }
    },

    {
      "name": "immediate: a non-bundle (no due) dispatches now, ahead of scheduled",
      "ops": [
        { "t": 0.0, "schedule": { "id": "later", "due": 5.0 } },
        { "t": 0.0, "send": { "id": "now" } }
      ],
      "expect": { "dispatched": ["now", "later"], "released_at": { "now": 0.0 } }
    },

    {
      "name": "cancelTag removes matching tag across all sessions",
      "ops": [
        { "t": 0.0, "schedule": { "id": "s0_r1_a", "due": 10.0, "session": 0, "tag": "run_1" } },
        { "t": 0.0, "schedule": { "id": "s1_r1_a", "due": 10.0, "session": 1, "tag": "run_1" } },
        { "t": 0.0, "schedule": { "id": "s0_r2_a", "due": 10.0, "session": 0, "tag": "run_2" } },
        { "t": 0.1, "cancelTag": "run_1" }
      ],
      "expect": { "dispatched": ["s0_r2_a"], "cancelled": 2 }
    },

    {
      "name": "cancelSession removes a session across all tags",
      "ops": [
        { "t": 0.0, "schedule": { "id": "s0_r1", "due": 10.0, "session": 0, "tag": "run_1" } },
        { "t": 0.0, "schedule": { "id": "s0_r2", "due": 10.0, "session": 0, "tag": "run_2" } },
        { "t": 0.0, "schedule": { "id": "s1_r1", "due": 10.0, "session": 1, "tag": "run_1" } },
        { "t": 0.1, "cancelSession": 0 }
      ],
      "expect": { "dispatched": ["s1_r1"], "cancelled": 2 }
    },

    {
      "name": "cancelSessionTag removes only the matching (session, tag) pair",
      "ops": [
        { "t": 0.0, "schedule": { "id": "s0_r1", "due": 10.0, "session": 0, "tag": "run_1" } },
        { "t": 0.0, "schedule": { "id": "s0_r2", "due": 10.0, "session": 0, "tag": "run_2" } },
        { "t": 0.0, "schedule": { "id": "s1_r1", "due": 10.0, "session": 1, "tag": "run_1" } },
        { "t": 0.1, "cancelSessionTag": { "session": 0, "tag": "run_1" } }
      ],
      "expect": { "dispatched": ["s0_r2", "s1_r1"], "cancelled": 1 }
    },

    {
      "name": "cancelAll empties the queue",
      "ops": [
        { "t": 0.0, "schedule": { "id": "a", "due": 10.0, "session": 0, "tag": "x" } },
        { "t": 0.0, "schedule": { "id": "b", "due": 10.0, "session": 1, "tag": "y" } },
        { "t": 0.1, "cancelAll": true }
      ],
      "expect": { "dispatched": [], "cancelled": 2 }
    },

    {
      "name": "cancel before due never dispatches; only the survivor releases on time",
      "lookahead_s": 0.5,
      "ops": [
        { "t": 0.0, "schedule": { "id": "doomed", "due": 4.0, "session": 0, "tag": "run_1" } },
        { "t": 0.0, "schedule": { "id": "kept",   "due": 4.0, "session": 0, "tag": "run_2" } },
        { "t": 2.0, "cancelTag": "run_1" }
      ],
      "expect": { "dispatched": ["kept"], "cancelled": 1, "released_at": { "kept": 3.5 } }
    },

    {
      "name": "reject: scheduled too far in the future (> max_future_s)",
      "max_future_s": 3600,
      "ops": [
        { "t": 0.0, "schedule": { "id": "soon", "due": 100.0 } },
        { "t": 0.0, "schedule": { "id": "way_off", "due": 4000.0 } }
      ],
      "expect": { "dispatched": ["soon"], "rejected": [{ "id": "way_off", "reason": "too_far_future" }] }
    },

    {
      "name": "reject: bundle larger than the scheduler pool slot",
      "pool_bytes": 1024,
      "ops": [
        { "t": 0.0, "schedule": { "id": "small", "due": 5.0, "bytes": 64 } },
        { "t": 0.0, "schedule": { "id": "huge",  "due": 5.0, "bytes": 4096 } }
      ],
      "expect": { "dispatched": ["small"], "rejected": [{ "id": "huge", "reason": "too_large" }] }
    },

    {
      "name": "reject: scheduling past the pending cap is backpressured",
      "max_pending": 2,
      "ops": [
        { "t": 0.0, "schedule": { "id": "p1", "due": 10.0 } },
        { "t": 0.0, "schedule": { "id": "p2", "due": 10.0 } },
        { "t": 0.0, "schedule": { "id": "p3", "due": 10.0 } }
      ],
      "expect": { "dispatched": ["p1", "p2"], "rejected": [{ "id": "p3", "reason": "queue_full" }] }
    },

    {
      "name": "ties in due time release in insertion (FIFO) order",
      "ops": [
        { "t": 0.0, "schedule": { "id": "a", "due": 1.0 } },
        { "t": 0.0, "schedule": { "id": "b", "due": 1.0 } },
        { "t": 0.0, "schedule": { "id": "c", "due": 1.0 } }
      ],
      "expect": { "dispatched": ["a", "b", "c"] }
    },

    {
      "name": "scheduling an already-past time releases immediately (at current clock)",
      "ops": [
        { "t": 1.0, "schedule": { "id": "past", "due": -5.0 } }
      ],
      "expect": { "dispatched": ["past"], "released_at": { "past": 1.0 } }
    },

    {
      "name": "cancel then reschedule the same tag keeps the new event",
      "ops": [
        { "t": 0.0, "schedule": { "id": "old", "due": 5.0, "session": 0, "tag": "run_1" } },
        { "t": 1.0, "cancelTag": "run_1" },
        { "t": 1.0, "schedule": { "id": "new", "due": 5.0, "session": 0, "tag": "run_1" } }
      ],
      "expect": { "dispatched": ["new"], "cancelled": 1, "released_at": { "new": 4.5 } }
    }
  ]
}

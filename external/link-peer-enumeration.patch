   std::size_t numPeers() const;
+
+  /*! @brief SUPERSONIC PATCH: enumerate currently-known peers in our
+   *  Link session with their IP addresses and NodeState info.
+   *  Returns by value (stable snapshot). Not RT-safe.
+   *  Thread-safe: yes
+   *  Realtime-safe: no
+   */
+  std::vector<std::pair<link::PeerState, discovery::IpAddress>>
+    sessionPeers() const
